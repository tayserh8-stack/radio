import React from 'react';
import { BrowserRouter as Router, Routes, Route, Navigate } from 'react-router-dom';
import MainLayout from './layout/MainLayout';
import Dashboard from './pages/Dashboard';
import WorkflowManagement from './pages/WorkflowManagement';
import PoliciesProcedures from './pages/PoliciesProcedures';
import InternalControlsAudit from './pages/InternalControlsAudit';
import TechnicalIntegrationPanel from './pages/TechnicalIntegrationPanel';
import ReportsAnalytics from './pages/ReportsAnalytics';
import PayrollProcessingInterface from './pages/PayrollProcessingInterface';
import EmployeeListPage from './features/employee/pages/EmployeeList';
import AttendancePage from './pages/Employee/Attendance';
import LeaveManagementPage from './pages/Employee/LeaveRequest';
import WellBeingCheckInPage from './pages/WellBeingCheckIn';
import WellBeingDashboardPage from './pages/WellBeingDashboard';
import ManagerEvaluationPage from './pages/ManagerEvaluation';
import ManagerEvaluationDashboard from './pages/ManagerEvaluationDashboard';
import EmployeeDashboard from './pages/Employee/EmployeeDashboard';
import MyTasks from './pages/Employee/MyTasks';
import AddTask from './pages/Employee/AddTask';
import TaskHistory from './pages/Employee/TaskHistory';
import EmployeeProfile from './features/employee/pages/EmployeeProfile';
import ChangePassword from './pages/Employee/ChangePassword';
import DocumentManagement from './features/employee/pages/DocumentManagement';
import AdminDashboard from './pages/Admin/AdminDashboard';
import ManagerDashboard from './pages/Manager/ManagerDashboard';
import AuditLogs from './pages/Admin/AuditLogs';
import AssignTasks from './pages/Manager/AssignTasks';
import EvaluateTasks from './pages/Manager/EvaluateTasks';
import DepartmentReports from './pages/Manager/DepartmentReports';
import AllReports from './pages/Admin/AllReports';
import Settings from './pages/Admin/Settings';
import Rankings from './pages/Admin/Rankings';
import BonusManagement from './components/BonusManagement';
import TaskDetail from './pages/TaskDetail';
import Messages from './pages/messages/Messages';
import WellBeingCheckIn from './pages/WellBeingCheckIn';
import WellBeingDashboard from './pages/WellBeingDashboard';
import ManagerEvaluation from './pages/ManagerEvaluation';
import Attendance from './pages/Employee/Attendance';
import LeaveRequest from './pages/Employee/LeaveRequest';
import PayrollManagement from './features/payroll/pages/PayrollManagement';
import PayrollDashboard from './features/payroll/pages/PayrollDashboard';
import PayrollWorkflow from './features/payroll/pages/PayrollWorkflow';
import PayrollPolicies from './features/payroll/pages/PayrollPolicies';
import PayrollAudit from './features/payroll/pages/PayrollAudit';
import PayrollIntegration from './features/payroll/pages/PayrollIntegration';
import PayrollReports from './features/payroll/pages/PayrollReports';
import PayrollProcessing from './features/payroll/pages/PayrollProcessing';
import Login from './pages/Auth/Login';
import Register from './pages/Auth/Register';
import './styles/global.css';

function App() {
  return (
    <Router>
      <Routes>
        <Route path="/login" element={<Login />} />
        <Route path="/register" element={<Register />} />
        <Route path="/*" element={
          <MainLayout>
            <Routes>
              <Route path="/" element={<EmployeeDashboard />} />
              <Route path="/dashboard" element={<Navigate to="/" replace />} />
              <Route path="/employee-dashboard" element={<EmployeeDashboard />} />
              <Route path="/admin/dashboard" element={<AdminDashboard />} />
              <Route path="/manager/dashboard" element={<ManagerDashboard />} />
              
              {/* Tasks */}
              <Route path="/tasks" element={<MyTasks />} />
              <Route path="/tasks/add" element={<AddTask />} />
              <Route path="/tasks/history" element={<TaskHistory />} />
              <Route path="/tasks/:id" element={<TaskDetail />} />
              
              {/* Profile */}
              <Route path="/profile" element={<EmployeeProfile />} />
              <Route path="/change-password" element={<ChangePassword />} />
              
              {/* Employees */}
              <Route path="/employees" element={<EmployeeListPage />} />
              <Route path="/admin/employees" element={<EmployeeListPage />} />
              
              {/* Attendance */}
              <Route path="/attendance" element={<AttendancePage />} />
              <Route path="/admin/attendance" element={<AttendancePage />} />
              
              {/* Leave Management */}
              <Route path="/leave-management" element={<LeaveManagementPage />} />
              <Route path="/admin/leave-management" element={<LeaveManagementPage />} />
              <Route path="/leave-request" element={<LeaveManagementPage />} />
              
              {/* Well-being */}
              <Route path="/well-being" element={<WellBeingCheckInPage />} />
              <Route path="/well-being/dashboard" element={<WellBeingDashboardPage />} />
              <Route path="/admin/well-being" element={<WellBeingDashboardPage />} />
              <Route path="/wellbeing/checkin" element={<WellBeingCheckInPage />} />
              <Route path="/wellbeing/dashboard" element={<WellBeingDashboardPage />} />
              
              {/* Manager Evaluation */}
              <Route path="/manager-evaluation" element={<ManagerEvaluationPage />} />
              <Route path="/admin/manager-evaluation" element={<ManagerEvaluationPage />} />
              <Route path="/manager-evaluation-dashboard" element={<ManagerEvaluationDashboard />} />
              
              {/* Payroll */}
              <Route path="/payroll" element={<PayrollManagement />} />
              <Route path="/payroll/dashboard" element={<PayrollDashboard />} />
              <Route path="/payroll/workflow" element={<PayrollWorkflow />} />
              <Route path="/payroll/policies" element={<PayrollPolicies />} />
              <Route path="/payroll/audit" element={<PayrollAudit />} />
              <Route path="/payroll/integration" element={<PayrollIntegration />} />
              <Route path="/payroll/reports" element={<PayrollReports />} />
              <Route path="/payroll/processing" element={<PayrollProcessing />} />
              
              {/* Documents */}
              <Route path="/documents" element={<DocumentManagement />} />
              
              {/* Messages */}
              <Route path="/messages" element={<Messages />} />
              
              {/* Admin */}
              <Route path="/admin/audit-logs" element={<AuditLogs />} />
              <Route path="/admin/reports" element={<AllReports />} />
              <Route path="/admin/settings" element={<Settings />} />
              <Route path="/admin/rankings" element={<Rankings />} />
              
              {/* Manager */}
              <Route path="/manager/assign-tasks" element={<AssignTasks />} />
              <Route path="/manager/evaluate-tasks" element={<EvaluateTasks />} />
              <Route path="/manager/reports" element={<DepartmentReports />} />
              
              {/* Bonus */}
              <Route path="/bonus" element={<BonusManagement />} />
              <Route path="/admin/bonuses" element={<BonusManagement />} />
              
              {/* Recruitment Performance */}
              <Route path="/recruitment-performance" element={<TaskDetail />} />
              
              {/* Default/Original Payroll Routes */}
              <Route path="/workflow" element={<WorkflowManagement />} />
              <Route path="/policies" element={<PoliciesProcedures />} />
              <Route path="/audit" element={<InternalControlsAudit />} />
              <Route path="/integrations" element={<TechnicalIntegrationPanel />} />
              <Route path="/reports" element={<ReportsAnalytics />} />
              <Route path="/payroll-processing" element={<PayrollProcessingInterface />} />
              
              {/* Catch-all */}
              <Route path="*" element={<Navigate to="/" replace />} />
            </Routes>
          </MainLayout>
        } />
      </Routes>
    </Router>
  );
}

export default App;